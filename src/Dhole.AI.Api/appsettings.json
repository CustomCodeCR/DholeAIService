  "Redis": {
    "ConnectionString": "localhost:6379",
    "InstanceName": "dhole_ai:",
    "DefaultExpirationMinutes": 30,
    "LockExpirationSeconds": 60,
    "EnableHealthCheck": true,
    "Streams": {
      "Enabled": true,
      "DefaultStreamName": "dhole.ai.events",
      "SourceService": "DholeAIService",
      "Destinations": {
        "audit.event.registered": "dhole.audit.events",
        "notifications.notification.requested": "dhole.notifications.events",
        "reports.report.requested": "dhole.reports.events"
      },
      "Publisher": {
        "MaxLength": 10000,
        "UseApproximateMaxLength": true
      },
      "Consumer": {
        "Enabled": true,
        "StreamName": "dhole.ai.events",
        "ConsumerGroup": "dhole-ai",
        "ConsumerName": "dhole-ai-worker",
        "BatchSize": 50,
        "PollingIntervalSeconds": 5,
        "ReadPendingMessages": true,
        "ErrorDelaySeconds": 10
      }
    }
  },
  "ConfigRedis": {
    "RevokedTokenPrefix": "auth:revoked_tokens:",
    "SessionPrefix": "auth:sessions:",
    "DefaultExpirationMinutes": 30
  },
  "Mongo": {
    "ConnectionString": "mongodb://mongo:turbodiesel@localhost:27017/?authSource=admin",
    "DatabaseName": "dhole_ai",
    "EnableHealthCheck": true
  },
  "Security": {
    "LoginRateLimit": {
      "MaxFailedAttempts": 5,
      "WindowMinutes": 15,
      "BlockMinutes": 15
    }
  },
  "Messaging": {
    "Outbox": {
      "BatchSize": 50,
      "MaxRetryCount": 3,
      "PollingIntervalSeconds": 10,
      "BackgroundService": {
        "Enabled": true,
        "PollingIntervalSeconds": 10,
        "BatchSize": 50,
        "RunImmediately": true,
        "ErrorDelaySeconds": 5,
        "UseDistributedLock": false,
        "LockDurationSeconds": 60
      }
    },
    "Inbox": {
      "ProcessedMessageExpirationDays": 7,
      "Cleanup": {
        "Enabled": true,
        "OlderThanDays": 7,
        "BatchSize": 100,
        "PollingIntervalSeconds": 300,
        "RunImmediately": true
      }
    }
  },
  "Workers": {
    "Enabled": true,
    "MaxRetryCount": 3,
    "RetryDelaySeconds": 5,
    "UseDistributedLock": false,
    "LockDurationSeconds": 60,
    "StopOnUnhandledException": false,
    "Schedule": {
      "IntervalSeconds": 300,
      "RunImmediately": true
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://0.0.0.0:5206",
        "Protocols": "Http1AndHttp2"
      },
      "Grpc": {
        "Url": "http://0.0.0.0:5307",
        "Protocols": "Http2"
      }
    }
  },
  "AI": {
    "DefaultProfiles": {
      "Enabled": true,
      "RetrySeconds": 30,
      "MaximumModelsPerProfile": 5
    }
  }
}
