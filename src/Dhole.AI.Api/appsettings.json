  "Postgres": {
    "ConnectionString": "Host=localhost;Port=5432;Database=dhole_ai;Username=postgres;Password=turbodiesel",
    "CommandTimeoutSeconds": 30,
    "EnableHealthCheck": true
  },
  "Auth": {
    "Jwt": {
      "Issuer": "DholeAuthService",
      "Audience": "DholeEcosystem",
      "SecretKey": "YElePTVO/+xgbecNV8qe1CMWvRoqi4+rfhgm4d9WSvKul+PKw2D0IdOnLzh/xH/vPJcIzvs+c5Lpwr6HQPpxZw==",
      "ExpirationMinutes": 30,
      "RequireHttpsMetadata": false
    },
    "ApiKey": {
      "HeaderName": "X-Api-Key",
      "Keys": []
